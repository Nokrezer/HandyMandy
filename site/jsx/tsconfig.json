{
  "compilerOptions": {
    "target": "ES2020",
    "module": "ESNext",
    "jsx": "react",
    "moduleResolution": "node",
    "ignoreDeprecations": "6.0",
    "outDir": "../js",
    "rootDir": "./",
    "esModuleInterop": true,
    "skipLibCheck": true,
    "allowJs": true
  },
  "include": ["/**/*"],
  "exclude": ["node_modules", "dist"]
}