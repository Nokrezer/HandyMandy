{
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview"
  },
  "compilerOptions": {
    "target": "ES2020",
    "module": "ESNext",
    "jsx": "react-jsx",
    "moduleResolution": "node",
    "outDir": "../js",
    "esModuleInterop": true,
    "skipLibCheck": true,
    "allowJs": true,
    "noEmitOnError": false,
    "strict": false
  },
  "include": [
    "**/*"
  ],
  "exclude": [
    "node_modules",
    "dist",
    ".git"
  ],
  "devDependencies": {
    "@vitejs/plugin-react": "^6.0.1",
    "esbuild": "^0.28.0",
    "vite": "^8.0.11",
    "webpack-cli": "^7.0.2"
  },
  "dependencies": {
    "@remix-run/router": "^1.23.2",
    "history": "^5.3.0",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "react-hot-toast": "^2.6.0",
    "react-router-dom": "^7.15.0",
    "typescript": "^6.0.3"
  }
}
